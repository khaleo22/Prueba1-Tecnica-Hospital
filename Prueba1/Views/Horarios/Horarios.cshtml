@model IEnumerable<HorarioMedico>
@{
    Layout = "_Layout";
}


<div class="card shadow-sm mb-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">Registrar Horarios de Médicos</h5>
    </div>
    <div class="card-body">
        <form asp-action="Guardar" method="post">
            <!-- Dropdown de médicos -->
            <div class="mb-3">
                <label class="form-label">Seleccionar Médico</label>
                <select id="idMedico" name="idMedico" class="form-select" required>
                    <option value="">-- Selecciona un médico --</option>
                    @foreach (var d in ViewBag.Doctores as List<Doctor>)
                    {
                        <option value="@d.Id">@d.Nombre @d.APaterno - @d.EspecialidadConcepto</option>
                    }
                </select>
            </div>

            <!-- Checkboxes de días -->
            <div class="mb-3">
                <label class="form-label">Días de la semana</label><br />
                @foreach (var dia in new[] { "Lunes", "Martes", "Miércoles", "Jueves", "Viernes", "Sábado", "Domingo" })
                {
                    <div class="form-check form-check-inline">
                        <input class="form-check-input" type="checkbox" name="dias" value="@dia"> @dia
                    </div>
                }
            </div>

            <!-- Horas -->
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">Hora Inicio</label>
                    <input type="time" name="horaInicio" class="form-control" required />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Hora Fin</label>
                    <input type="time" name="horaFin" class="form-control" required />
                </div>
            </div>

            <div class="d-flex justify-content-end">
                <button type="submit" class="btn btn-success">Guardar</button>
            </div>
        </form>
    </div>
</div>

<!-- Listado de horarios -->
<div class="card shadow-sm">
    <div class="card-header bg-dark text-white">
        <h5 class="mb-0">Horarios Registrados</h5>
    </div>
    <div class="card-body">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Médico</th>
                    <th>Día</th>
                    <th>Hora Inicio</th>
                    <th>Hora Fin</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var h in Model)
                    {
                        <tr>
                            <td>@h.NombreMedico</td>
                            <td>@h.Dia</td>
                            <td>@h.HoraInicio</td>
                            <td>@h.HoraFin</td>
                            <td class="text-center">
                                <button class="btn btn-warning btnEditarHorario"
                                        data-id="@h.Id"
                                        data-doctor="@h.IdMedico"
                                        data-dia="@h.Dia"
                                        data-inicio="@h.HoraInicio"
                                        data-fin="@h.HoraFin"
                                        data-estatus="@h.Estatus">
                                    Editar
                                </button>

                                <button class="btn btn-danger btnEliminarHorario"
                                        data-id="@h.Id">
                                    Eliminar
                                </button>

                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">No hay horarios registrados</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var message = '@TempData["SwalMessage"]';
            var type = '@TempData["SwalType"]';

            if (message && type) {
                Swal.fire({
                    icon: type,
                    title: type === "success" ? "Éxito" : "Error",
                    text: message,
                    confirmButtonColor: '#3085d6'
                });
            }
        });
    </script>
}

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="~/js/horarios.js"></script>



