<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - Mi Aplicación MVC</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>
<body>
    <header>
        <nav class="navbar">
            <div class="navbar-brand">Prueba Tecnica</div>
            <ul class="navbar-menu">
                <li><a asp-controller="Doctores" asp-action="Doctores">👤 Doctores</a></li>
                <li><a asp-controller="Pacientes" asp-action="Paciente">🏥 Pacientes</a></li>
                <li><a asp-controller="Horarios" asp-action="Horarios">🗓️ Horarios</a></li>
                <li><a asp-controller="Citas" asp-action="Agendar">🗓️ Agendar Cita</a></li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="AgendaMedico" asp-action="AgendaMedicos" asp-route-idMedico="1" asp-route-fecha="@DateTime.Now.ToString("yyyy-MM-dd")">
                        🗓️ Agenda Médico
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Historial" asp-action="CitasPaciente">
                        📖 Historial Paciente
                    </a>
                </li>
                <li><a asp-controller="Login" asp-action="Index">🔒 Cerrar sesión</a></li>
            </ul>
        </nav>
    </header>

    <main class="container">
        @RenderBody()
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    </main>

    <footer>
        <p>© 2026 Mi Aplicación MVC</p>
    </footer>

    @RenderSection("Scripts", required: false)
</body>
</html>

